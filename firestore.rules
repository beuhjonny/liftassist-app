rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Top-level system collections: managed securely by Cloud Functions only
    match /auth_tokens/{tokenId} {
      allow read, write: if false;
    }

    match /pairing_codes/{codeId} {
      allow read, write: if false;
    }

    // Public Shared Workout Cards:
    // Anyone (including unauthenticated visitors) can read shared cards.
    // Only logged-in owners can create or update/delete their own shared cards.
    match /public_workouts/{shareId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // User Subtree Rules: User has full access to their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
