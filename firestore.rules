rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Top-level system collections: managed securely by Cloud Functions only
    match /auth_tokens/{tokenId} {
      allow read, write: if false;
    }

    match /pairing_codes/{codeId} {
      allow read, write: if false;
    }

    // User Subtree Rules: User has full access to their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
